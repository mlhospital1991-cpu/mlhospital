generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Appointment {
  id        String   @id @default(cuid())
  name      String
  location  String?
  issue     String?
  doctor    String
  date      String
  time      String
  status    String   @default("pending") // pending, forwarded, completed
  opNumber  String?
  createdAt DateTime @default(now())
}

model User {
  id          String   @id @default(cuid())
  username    String   @unique
  password    String   // Hashed
  name        String
  role        String   @default("NURSE") // ADMIN, DOCTOR, NURSE
  permissions String   @default("[]")    // JSON stringified array of permission strings
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
